# ═══════════════════════════════════════════════════════
#  JobTracker Pro — Environment Variables
#  1. Copy this file:  copy .env.example .env
#  2. Fill in your values in .env
#  3. NEVER commit .env to Git
# ═══════════════════════════════════════════════════════

# ── Flask ─────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=True

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-64-char-string

# ── JWT ───────────────────────────────────────────────
# Generate separately from SECRET_KEY
JWT_SECRET_KEY=replace-with-another-random-64-char-string
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# ── PostgreSQL ────────────────────────────────────────
# Format: postgresql://username:password@host:port/database_name
# Local default (change password to yours):
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/jobtracker

# ── Redis ─────────────────────────────────────────────
# Local default (no password on fresh Redis install):
REDIS_URL=redis://localhost:6379/0

# ── LinkedIn OAuth ────────────────────────────────────
# Create an app at: https://www.linkedin.com/developers/apps
# Add product: "Sign In with LinkedIn using OpenID Connect"
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/linkedin/callback

# ── SendGrid (Email) ──────────────────────────────────
# Sign up at: https://sendgrid.com (free tier = 100 emails/day)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@jobtracker.app
FROM_NAME=JobTracker Pro

# ── AWS S3 (Resume Storage) ───────────────────────────
# Create a bucket in ap-south-1 (Mumbai) for low latency
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=jobtracker-resumes

# ── Encryption Key ────────────────────────────────────
# Used to encrypt TOTP secrets and OAuth tokens in the DB
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Inbound Email (for email forwarding feature) ──────
# The domain your users forward recruiter emails to
# e.g. abc123@mail.jobtracker.app
INBOUND_EMAIL_DOMAIN=mail.jobtracker.app

# ── Frontend ──────────────────────────────────────────
# Used for CORS and building redirect URLs in emails
FRONTEND_URL=http://localhost:5173

# ── App ───────────────────────────────────────────────
APP_NAME=JobTracker Pro